# Sao chép file này thành `.env` và điền giá trị thật. KHÔNG commit .env.

# --- OpenAI API (Bước 3: LLM extraction) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONCURRENCY=5            # số request đồng thời
OPENAI_BASE_URL=                # để trống = api.openai.com (đổi nếu dùng proxy/Azure)

# --- Neo4j (Bước 6: load + Bước 7: query) ---
# Neo4j Desktop: lấy bolt URI và password ở tab "Connection details" của DBMS
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# --- Embedding (Bước 5) ---
# Tên model trên HuggingFace; mặc định BGE-M3 (multilingual, 1024d)
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_DEVICE=cpu        # đổi 'cuda' nếu có GPU NVIDIA

# --- Đường dẫn dữ liệu ---
LAW_DOCX_PATH=data/raw/Luật-41-2024-QH15.docx
LAW_CODE=41/2024/QH15
LAW_ID=L41_2024
