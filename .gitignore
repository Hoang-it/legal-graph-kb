# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor.`.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# ---------------------------------------------------------------------------
# legal-graph-kb project-specific
# ---------------------------------------------------------------------------

# Generated pipeline data (regenerable; do NOT commit ALL EXCEPT explicit
# whitelist below). Use `dir/*` form so we CAN re-include specific files.
data/graph/interim/*
data/graph/processed/*

# User-provided evaluation data — except 200-question benchmark
data/eval/questions_*.json

# ─── EXCEPTIONS: KG artifacts needed to reproduce inference ───
!data/eval/questions_200.json
# v5 Sprint 2 Phase 0b — hash-sealed split (committed, must stay bit-identical)
!data/eval/questions_150_test.json
!data/eval/questions_50_dev.json
!data/eval/eval_split_hashes.json
!data/graph/interim/structured_law.json
!data/graph/processed/merged_graph.json
!data/graph/processed/embeddings.parquet
# v5 Sprint 2 Phase 3 — tuned embeddings are large + reproducible from the
# adapter, so they remain gitignored.
data/graph/processed/embeddings_tuned.parquet
# v5 Sprint 2 Phase 1 — synthetic training data + audit artifacts (committed)
!data/finetune-bge/
!data/finetune-bge/**

# Backup snapshots from audit fixes
*.bak
*.bak_*

# Logs
logs/

# Allow placeholder files so empty dirs are kept
!data/**/.gitkeep
!data/graph/raw/.gitkeep

# ─── Experiment results — ignored by default, per-experiment opt-in ───
# Each experiment can override this in its own .gitignore (see e.g.
# experiments/01_initial_eval/.gitignore which un-ignores results/ to
# freeze its baseline records for inheritance by future experiments).
experiments/*/results/

# ─── Runtime-generated artifacts (Prolog programs from logic-LM CLI etc.) ───
# Peer of source dirs (runtime/, offline/, src/). Regenerable; do NOT commit.
artifacts/

# Model caches & weights (downloaded on demand via scripts/install_b5.ps1)
.cache/
*.safetensors
*.bin
*.onnx

# Sprint 2 LoRA adapter — produced on Colab, uploaded by user (not committed by size)
models/

# Neo4j dumps
*.dump

# Scratch / temp files at repo root
scratch_*.py
tmp_*.py
*.tmp

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
