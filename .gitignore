# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor.`.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# ---------------------------------------------------------------------------
# legal-graph-kb project-specific
# ---------------------------------------------------------------------------

# Generated pipeline data (regenerable; do NOT commit ALL EXCEPT explicit
# whitelist below). Use `dir/*` form so we CAN re-include specific files.
data/interim/*
data/processed/*
data/eval/results/*
data/eval/metrics.json
data/eval/metrics.csv
data/eval/metrics*.json
data/eval/metrics*.csv
data/eval/academic_metrics_*.json
data/eval/academic_metrics_*.csv
data/eval/academic/first*/
data/eval/academic/*_results/
data/eval/academic/questions_*.json
data/eval/judge_cache.jsonl
data/eval/multimodel/judge_cache.jsonl
data/eval/multimodel/metrics*.json
data/eval/multimodel/metrics*.csv

# Backup snapshots from audit fixes
*.bak
*.bak_*

# Logs
logs/

# Auxiliary CSV outputs (regenerable)
reports/*.csv

# User-provided evaluation data — except 200-question benchmark
data/eval/questions_*.json

# ─── EXCEPTIONS: files needed for Colab notebooks to reproduce experiment ───
!data/eval/questions_200.json
!data/interim/structured_law.json
!data/processed/merged_graph.json
!data/processed/embeddings.parquet

# ─── R1 experiment snapshot (committed cho reproducibility, ~10MB total) ───
# Re-include results/ dir + downstream artifacts. User có thể skip Phase 2
# inference trên Colab và nhảy thẳng vào metric compute / report rendering.
!data/eval/results/
!data/eval/results/**
!data/eval/academic_metrics.json
!data/eval/academic_metrics.csv
!data/eval/academic/
!data/eval/academic/gold_citations_normalized.json

# Allow placeholder files so empty dirs are kept
!data/**/.gitkeep
!data/raw/.gitkeep

# Generated reports
reports/*.md
!reports/.gitkeep
# Human-written documentation (commit these)
!reports/academic_report.md
!reports/extraction_summary.md

# Model caches & weights (downloaded on demand via scripts/install_b5.ps1)
.cache/
*.safetensors
*.bin
*.onnx

